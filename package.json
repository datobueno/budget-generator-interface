{
  "name": "budget-generator-interface",
  "description": "React app for building quotes, previewing printable sheets, and exporting client-facing PDFs, maintained by the datobueno association.",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "datobueno association",
  "funding": "https://github.com/sponsors/datobueno",
  "homepage": "https://github.com/datobueno/budget-generator-interface#readme",
  "bugs": {
    "url": "https://github.com/datobueno/budget-generator-interface/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datobueno/budget-generator-interface.git"
  },
  "keywords": [
    "budget",
    "quote",
    "pdf",
    "react",
    "vite",
    "open-source"
  ],
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "dev:lan": "vite --host 0.0.0.0 --port 5173",
    "build": "tsc --noEmit --incremental false && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "preview:lan": "vite preview --host 0.0.0.0 --port 4173",
    "doctor": "bash scripts/doctor.sh",
    "doctor:network": "bash scripts/doctor.sh --network",
    "repair:deps": "bash scripts/repair-deps.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-pdf/renderer": "^4.3.2",
    "@tailwindcss/vite": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.576.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "jsdom": "^28.1.0",
    "shadcn": "^3.8.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48"
}
